    },
    "visitorId": {
      "@id": "tealium:visitorId",
      "@type": "xsd:string"
    },
    "attributeId": {
      "@id": "tealium:attributeId",
      "@type": "xsd:integer"
    },
    "attributeValue": {
      "@id": "tealium:attributeValue",
      "@type": "xsd:string"
    },
    "eventType": {
      "@id": "tealium:eventType",
      "@type": "xsd:string"
    },
    "datasourceKey": {
      "@id": "tealium:datasourceKey",
      "@type": "xsd:string"
    },
    "engineId": {
      "@id": "tealium:engineId",
      "@type": "xsd:string"
    },
    "transactionId": {
      "@id": "tealium:transactionId",
      "@type": "xsd:string"
    },
