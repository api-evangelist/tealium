{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "tealium": "https://tealium.com/vocab/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "name": "schema:name",
    "description": "schema:description",
    "url": "schema:url",
    "version": "schema:version",

    "TealiumAccount": {
      "@id": "tealium:Account",
      "@type": "@id"
    },
    "TealiumProfile": {
      "@id": "tealium:Profile",
      "@type": "@id"
    },
    "TealiumVisitor": {
      "@id": "tealium:Visitor",
