    },
    "TealiumAttribute": {
      "@id": "tealium:Attribute",
      "@type": "@id"
    },
    "TealiumEngine": {
      "@id": "tealium:Engine",
      "@type": "@id"
    },
    "TealiumTag": {
      "@id": "tealium:Tag",
